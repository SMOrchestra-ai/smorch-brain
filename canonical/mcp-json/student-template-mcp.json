{
  "mcpServers": {
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "@n8n/mcp-server"
      ],
      "env": {
        "N8N_BASE_URL": "${N8N_BASE_URL}",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer ${LINEAR_API_KEY}"
      }
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@anthropic-ai/mcp-playwright"
      ]
    },
    "clay": {
      "command": "npx",
      "args": [
        "-y",
        "clay-mcp-server"
      ],
      "env": {
        "CLAY_API_KEY": "${CLAY_API_KEY}"
      }
    },
    "instantly": {
      "command": "npx",
      "args": [
        "instantly-mcp",
        "--api-key",
        "${INSTANTLY_API_KEY}"
      ]
    },
    "contabo-server": {
      "command": "node",
      "args": [
        "/Users/mamounalamouri/Desktop/cowork-workspace/CodingProjects/contabo-mcp-project/contabo-mcp-server/packages/contabo-mcp/dist/index.js"
      ],
      "env": {
        "CONTABO_CLIENT_ID": "${CONTABO_CLIENT_ID}",
        "CONTABO_CLIENT_SECRET": "${CONTABO_CLIENT_SECRET}",
        "CONTABO_API_USER": "${CONTABO_API_USER}",
        "CONTABO_API_PASSWORD": "${CONTABO_API_PASSWORD}"
      }
    },
    "ssh-mcp": {
