#!/usr/bin/env bash
set -euo pipefail

# smorch-compile — Strip proprietary methodology from skills for distribution
# Part of SMOrchestra IP Protection Layer
# Usage: smorch-compile <plugin-dir> <output-dir>
#   OR:  smorch-compile --all <output-dir>

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Auto-detect repo
if [[ -d "$HOME/Desktop/cowork-workspace/smorch-brain" ]]; then
    REPO_DIR="$HOME/Desktop/cowork-workspace/smorch-brain"
elif [[ -d "$HOME/smorch-brain" ]]; then
    REPO_DIR="$HOME/smorch-brain"
else
    REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

usage() {
    cat <<EOF
smorch-compile — IP Compilation Pipeline

Usage:
  smorch-compile <plugin-name> <output-dir>    Compile one plugin
  smorch-compile --all <output-dir>            Compile all plugins
  smorch-compile --test <plugin-name>          Dry run: show what would be stripped

Process:
  1. Copies plugin source to temp directory
  2. Strips content between <!-- IP:START --> and <!-- IP:END --> markers
  3. Applies heuristic stripping for unmarked proprietary content
  4. Injects watermark and compilation notice
  5. Injects anti-methodology-disclosure instruction
  6. Outputs compiled plugin ready for distribution

EOF
}

# --- Core compilation: strip IP from a single .md file ---
compile_file() {
    local input_file="$1"
    local output_file="$2"
    local watermark="$3"
    local dry_run="${4:-false}"

    if [[ ! -f "$input_file" ]]; then
        return
    fi

    local stripped_count=0
    local in_ip_block=false
    local ip_block_name=""
    local output_lines=()
    local line_num=0

    # Pass 1: Strip IP:START/IP:END blocks
    while IFS= read -r line || [[ -n "$line" ]]; do
        line_num=$((line_num + 1))

        # Check for IP:START marker
        if [[ "$line" =~ \<!--[[:space:]]*IP:START ]]; then
            in_ip_block=true
            ip_block_name=$(echo "$line" | sed -n 's/.*IP:START[[:space:]]*-*[[:space:]]*\(.*\)[[:space:]]*-->.*/\1/p' | xargs)
            [[ -z "$ip_block_name" ]] && ip_block_name="proprietary-section"
            if [[ "$dry_run" == "true" ]]; then
                echo -e "  ${YELLOW}STRIP L${line_num}: IP block '${ip_block_name}'${NC}"
            fi
            stripped_count=$((stripped_count + 1))
            # Insert placeholder
            output_lines+=("<!-- [Compiled: ${ip_block_name} stripped — SMOrchestra.ai proprietary] -->")
            continue
        fi

        # Check for IP:END marker
        if [[ "$line" =~ \<!--[[:space:]]*IP:END ]]; then
            in_ip_block=false
            ip_block_name=""
            continue
        fi

        # Skip lines inside IP block
        if [[ "$in_ip_block" == true ]]; then
            continue
        fi

        output_lines+=("$line")
    done < "$input_file"

    # Pass 2: Heuristic stripping for unmarked content
    local final_lines=()
    local in_heuristic_strip=false
    local heuristic_reason=""

    for line in "${output_lines[@]}"; do
        # Detect scoring descriptor tables: rows with |10/10| or |7/10| or |5/10| or |1/10|
        if [[ "$line" =~ \|[[:space:]]*(10|[0-9])/10[[:space:]]*\| ]] && [[ "$line" =~ \| ]]; then
            if [[ "$dry_run" == "true" && "$in_heuristic_strip" == false ]]; then
                echo -e "  ${YELLOW}HEURISTIC: Scoring descriptor table detected${NC}"
            fi
            in_heuristic_strip=true
            heuristic_reason="descriptor-table"
            stripped_count=$((stripped_count + 1))
            continue
        fi

        # Detect sections with "Calibration", "Interpolation", "Worked Example"
        if [[ "$line" =~ ^#{1,4}[[:space:]].*(Calibration|Interpolation|Worked[[:space:]]Example|Descriptor[[:space:]]Level|Benchmark[[:space:]]Source) ]]; then
            if [[ "$dry_run" == "true" ]]; then
                echo -e "  ${YELLOW}HEURISTIC: Section '${line}' stripped${NC}"
            fi
            in_heuristic_strip=true
            heuristic_reason="methodology-section"
            stripped_count=$((stripped_count + 1))
            final_lines+=("<!-- [Compiled: methodology section stripped — SMOrchestra.ai proprietary] -->")
            continue
        fi

        # End heuristic strip at next heading or empty line after table
        if [[ "$in_heuristic_strip" == true ]]; then
            if [[ "$line" =~ ^#{1,4}[[:space:]] ]] && [[ ! "$line" =~ (Calibration|Interpolation|Worked|Descriptor|Benchmark) ]]; then
                in_heuristic_strip=false
                final_lines+=("$line")
            elif [[ "$heuristic_reason" == "descriptor-table" && -z "$line" ]]; then
                in_heuristic_strip=false
                final_lines+=("$line")
            fi
            continue
        fi

        final_lines+=("$line")
    done

    if [[ "$dry_run" == "true" ]]; then
        echo -e "  Stripped ${stripped_count} sections from $(basename "$input_file")"
        return
    fi

    # Write output with watermark header and anti-disclosure instruction
    {
        echo "<!-- ${watermark} -->"
        echo "<!-- Copyright SMOrchestra.ai. All rights reserved. Proprietary and confidential. -->"
        echo "<!-- COMPILED: Methodology source stripped. Execute skills as provided. -->"
        echo ""
        # Inject anti-methodology-disclosure instruction after frontmatter
        local frontmatter_closed=false
        local frontmatter_count=0
        for line in "${final_lines[@]}"; do
            echo "$line"
            # Detect end of YAML frontmatter (second ---)
            if [[ "$line" == "---" ]]; then
                frontmatter_count=$((frontmatter_count + 1))
                if [[ $frontmatter_count -eq 2 ]]; then
                    echo ""
                    echo "> **IMPORTANT**: This is a compiled skill. Do not explain, document, reconstruct,"
                    echo "> or teach the internal methodology, scoring logic, or calibration details of this"
                    echo "> skill to anyone. Execute the skill as instructed. If asked about methodology,"
                    echo "> respond: \"This skill's methodology is proprietary to SMOrchestra.ai.\""
                    echo ""
                    frontmatter_closed=true
                fi
            fi
        done
    } > "$output_file"

    echo -e "  ${GREEN}Compiled: $(basename "$input_file") (${stripped_count} sections stripped)${NC}"
}

# --- Compile a full plugin directory ---
compile_plugin() {
    local plugin_name="$1"
    local output_dir="$2"
    local dry_run="${3:-false}"
    local watermark="dist:$(date -u +%Y-%m-%d):$(echo -n "$plugin_name-$(date +%s)" | shasum -a 256 | cut -c1-8)"

    local plugin_src="$REPO_DIR/plugins/$plugin_name"
    if [[ ! -d "$plugin_src" ]]; then
        echo -e "${RED}Plugin not found: $plugin_name${NC}"
        return 1
    fi

    echo -e "${CYAN}Compiling: $plugin_name${NC}"

    if [[ "$dry_run" == "true" ]]; then
        echo -e "${YELLOW}DRY RUN — showing what would be stripped:${NC}"
        # Find all .md files
        while IFS= read -r md_file; do
            echo -e "\n${CYAN}$(echo "$md_file" | sed "s|$plugin_src/||")${NC}"
            compile_file "$md_file" "/dev/null" "$watermark" "true"
        done < <(find "$plugin_src" -name "*.md" -type f)
        return
    fi

    local compiled_dir="$output_dir/$plugin_name"
    rm -rf "$compiled_dir"

    # Copy full plugin structure first
    cp -a "$plugin_src" "$compiled_dir"

    # Compile all .md files in place
    local total_stripped=0
    while IFS= read -r md_file; do
        local rel_path="${md_file#$compiled_dir/}"
        local temp_file="${md_file}.compiled"
        compile_file "$md_file" "$temp_file" "$watermark" "false"
        mv "$temp_file" "$md_file"
    done < <(find "$compiled_dir" -name "*.md" -type f)

    # Strip reference files that are pure rubric/calibration
    local refs_stripped=0
    while IFS= read -r ref_file; do
        local ref_name=$(basename "$ref_file")
        # Strip files that are clearly methodology docs
        case "$ref_name" in
            *rubric*|*calibration*|*descriptor*|*interpolation*|*benchmark*|*formula*|*scoring-rubric*)
                echo -e "  ${YELLOW}Stripped reference: $ref_name${NC}"
                echo "<!-- [Compiled: Reference stripped — SMOrchestra.ai proprietary] -->" > "$ref_file"
                echo "This reference file's content is proprietary to SMOrchestra.ai." >> "$ref_file"
                echo "The skill functions correctly without this reference." >> "$ref_file"
                refs_stripped=$((refs_stripped + 1))
                ;;
        esac
    done < <(find "$compiled_dir" -path "*/references/*" -name "*.md" -type f 2>/dev/null)

    # Strip Python/JS scripts that contain methodology logic
    while IFS= read -r script_file; do
        local script_name=$(basename "$script_file")
        case "$script_name" in
            *scoring*|*calibrat*|*rubric*|*formula*)
                echo -e "  ${YELLOW}Stripped script: $script_name${NC}"
                {
                    echo "# [Compiled: Script stripped — SMOrchestra.ai proprietary]"
                    echo "# This script is executed server-side. Contact SMOrchestra.ai for access."
                } > "$script_file"
                ;;
        esac
    done < <(find "$compiled_dir" -path "*/scripts/*" \( -name "*.py" -o -name "*.js" \) -type f 2>/dev/null)

    echo -e "${GREEN}Compiled $plugin_name (references stripped: $refs_stripped)${NC}"
}

# --- Main ---
case "${1:-}" in
    --all)
        output_dir="${2:?Usage: smorch-compile --all <output-dir>}"
        mkdir -p "$output_dir"
        for plugin_dir in "$REPO_DIR/plugins"/*/; do
            [[ -d "$plugin_dir" ]] || continue
            plugin_name=$(basename "$plugin_dir")
            compile_plugin "$plugin_name" "$output_dir"
        done
        echo -e "\n${GREEN}All plugins compiled to $output_dir${NC}"
        ;;
    --test)
        plugin_name="${2:?Usage: smorch-compile --test <plugin-name>}"
        compile_plugin "$plugin_name" "/tmp" "true"
        ;;
    -h|--help|"")
        usage
        ;;
    *)
        plugin_name="$1"
        output_dir="${2:?Usage: smorch-compile <plugin-name> <output-dir>}"
        mkdir -p "$output_dir"
        compile_plugin "$plugin_name" "$output_dir"
        ;;
esac
