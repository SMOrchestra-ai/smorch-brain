#!/usr/bin/env bash
set -euo pipefail

# smorch-publish-dist — Compile all plugins and publish to smorch-dist repo
# Part of SMOrchestra IP Protection Layer
# Usage: smorch-publish-dist [--dry-run]

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# Auto-detect repos
if [[ -d "$HOME/Desktop/cowork-workspace/smorch-brain" ]]; then
    SOURCE_REPO="$HOME/Desktop/cowork-workspace/smorch-brain"
elif [[ -d "$HOME/smorch-brain" ]]; then
    SOURCE_REPO="$HOME/smorch-brain"
else
    SOURCE_REPO="$(cd "$(dirname "$0")/.." && pwd)"
fi

DIST_REPO="$HOME/Desktop/cowork-workspace/smorch-dist"
COMPILE_SCRIPT="$SOURCE_REPO/scripts/smorch-compile"
TEMP_DIR=$(mktemp -d)

DRY_RUN=false
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

echo -e "${CYAN}╔══════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║  smorch-publish-dist — IP Protection     ║${NC}"
echo -e "${CYAN}╚══════════════════════════════════════════╝${NC}"

# --- Step 0: Verify dist repo exists ---
if [[ ! -d "$DIST_REPO" ]]; then
    echo -e "${YELLOW}smorch-dist not found at $DIST_REPO${NC}"
    echo -e "To set up:"
    echo -e "  1. Create repo: gh repo create SMOrchestra-ai/smorch-dist --private"
    echo -e "  2. Clone:       git clone git@github.com:SMOrchestra-ai/smorch-dist.git $DIST_REPO"
    echo -e "  3. Re-run this script"

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${YELLOW}DRY RUN: Would create dist repo structure in $TEMP_DIR${NC}"
        DIST_REPO="$TEMP_DIR/smorch-dist"
        mkdir -p "$DIST_REPO"
    else
        exit 1
    fi
fi

# --- Step 1: Compile all plugins ---
echo -e "\n${CYAN}Step 1: Compiling plugins (stripping methodology)...${NC}"
COMPILED_DIR="$TEMP_DIR/compiled-plugins"
mkdir -p "$COMPILED_DIR"

chmod +x "$COMPILE_SCRIPT" 2>/dev/null
"$COMPILE_SCRIPT" --all "$COMPILED_DIR"

# --- Step 2: Build .plugin ZIPs from compiled sources ---
echo -e "\n${CYAN}Step 2: Building .plugin archives from compiled sources...${NC}"
DIST_PLUGINS_DIR="$TEMP_DIR/dist"
mkdir -p "$DIST_PLUGINS_DIR"

for compiled_dir in "$COMPILED_DIR"/*/; do
    [[ -d "$compiled_dir" ]] || continue
    local_name=$(basename "$compiled_dir")
    output="$DIST_PLUGINS_DIR/${local_name}.plugin"

    cd "$compiled_dir"
    zip -r "$output" . \
        -x "*.DS_Store" \
        -x "*node_modules/*" \
        -x "*__pycache__/*" \
        -x "*.git/*" \
        2>/dev/null

    size=$(du -h "$output" | cut -f1)
    echo -e "  ${GREEN}Built: ${local_name}.plugin ($size)${NC}"
done

# --- Step 3: Prepare dist repo structure ---
echo -e "\n${CYAN}Step 3: Preparing dist repo structure...${NC}"

# Clean dist repo (preserve .git)
if [[ -d "$DIST_REPO/.git" ]]; then
    # Preserve git directory, clean everything else
    find "$DIST_REPO" -maxdepth 1 -mindepth 1 -not -name ".git" -exec rm -rf {} \; 2>/dev/null
fi

mkdir -p "$DIST_REPO/dist"
mkdir -p "$DIST_REPO/profiles"
mkdir -p "$DIST_REPO/scripts"

# Copy compiled plugins
cp "$DIST_PLUGINS_DIR"/*.plugin "$DIST_REPO/dist/" 2>/dev/null

# Copy compiled plugin directories (for Cowork Desktop workspace pointing)
mkdir -p "$DIST_REPO/plugins"
cp -a "$COMPILED_DIR"/* "$DIST_REPO/plugins/" 2>/dev/null

# Copy team CLAUDE.md (NOT the founder version)
cp "$SOURCE_REPO/claude-dist/CLAUDE.md" "$DIST_REPO/CLAUDE.md"

# Copy dist license
cp "$SOURCE_REPO/legal/dist-license.md" "$DIST_REPO/LICENSE.md"

# Copy team profiles only (NOT mamoun.txt)
for profile in "$SOURCE_REPO/profiles"/*.txt; do
    pname=$(basename "$profile" .txt)
    [[ "$pname" == "mamoun" ]] && continue  # Never distribute founder profile
    cp "$profile" "$DIST_REPO/profiles/"
done

# Generate dist-only smorch CLI (strip push/build/audit/compile commands)
cat > "$DIST_REPO/scripts/smorch" <<'DISTCLI'
#!/usr/bin/env bash
set -euo pipefail

# smorch (distribution) — SMOrchestra Skill Installer
# This is the team version. Source management commands are not available.

VERSION="2.0.0-dist"

if [[ -d "$HOME/Desktop/cowork-workspace/smorch-dist" ]]; then
    REPO_DIR="$HOME/Desktop/cowork-workspace/smorch-dist"
elif [[ -d "$HOME/smorch-dist" ]]; then
    REPO_DIR="$HOME/smorch-dist"
else
    REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fi

SKILLS_TARGET="$HOME/.claude/skills"
STATE_FILE="$REPO_DIR/.smorch-state"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    cat <<EOF
smorch v${VERSION} — SMOrchestra Skill Installer (Team Edition)

Usage: smorch <command> [options]

Commands:
  pull --profile <name>   Install skills for your profile
  list                    Show available skills
  list --installed        Show installed skills
  list --profiles         Show available profiles
  status                  Profile, last sync, skill counts
  init --profile <name>   First-time setup

Registry: ${REPO_DIR}
Skills:   ${SKILLS_TARGET}
EOF
}

load_state() {
    CURRENT_PROFILE=""
    LAST_SYNC=""
    if [[ -f "$STATE_FILE" ]]; then
        source "$STATE_FILE"
    fi
}

save_state() {
    cat > "$STATE_FILE" <<EOF
CURRENT_PROFILE="${CURRENT_PROFILE}"
LAST_SYNC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
EOF
}

cmd_pull() {
    load_state
    local profile="${CURRENT_PROFILE}"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            --force) shift ;;
            *) echo "Unknown: $1"; return 1 ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}ERROR: No profile set. Run: smorch pull --profile <name>${NC}"
        ls "$REPO_DIR/profiles/"*.txt 2>/dev/null | xargs -I{} basename {} .txt | sed 's/^/  /'
        return 1
    fi

    echo -e "${CYAN}smorch pull — Syncing profile: $profile${NC}"

    cd "$REPO_DIR"
    git pull --rebase origin main 2>&1 || true

    # Install team CLAUDE.md
    if [[ -f "$REPO_DIR/CLAUDE.md" ]]; then
        cp "$REPO_DIR/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
        echo -e "  ${GREEN}Installed team CLAUDE.md${NC}"
    fi

    # Verify hash integrity
    if [[ -f "$REPO_DIR/dist/.manifest" ]]; then
        echo -e "  Verifying plugin integrity..."
        local failures=0
        while IFS='  ' read -r expected_hash filename; do
            [[ -z "$expected_hash" ]] && continue
            local actual_hash=$(shasum -a 256 "$REPO_DIR/dist/$filename" 2>/dev/null | cut -d' ' -f1)
            if [[ "$expected_hash" != "$actual_hash" ]]; then
                echo -e "  ${RED}INTEGRITY FAILURE: $filename${NC}"
                failures=$((failures + 1))
            fi
        done < "$REPO_DIR/dist/.manifest"
        if [[ $failures -gt 0 ]]; then
            echo -e "${RED}$failures plugin(s) failed integrity check. Contact admin.${NC}"
            return 1
        fi
        echo -e "  ${GREEN}All plugins verified.${NC}"
    fi

    CURRENT_PROFILE="$profile"
    save_state
    echo -e "${GREEN}Profile '$profile' installed. Plugins available in $REPO_DIR/plugins/${NC}"
}

cmd_status() {
    load_state
    echo -e "${CYAN}smorch status (team edition)${NC}"
    echo "──────────────────────────────────"
    echo -e "Profile:    ${GREEN}${CURRENT_PROFILE:-<not set>}${NC}"
    echo -e "Last sync:  ${LAST_SYNC:-never}"
    echo -e "Registry:   $REPO_DIR"

    local plugin_count=$(ls "$REPO_DIR/dist/"*.plugin 2>/dev/null | wc -l | xargs)
    echo -e "Plugins:    ${GREEN}$plugin_count available${NC}"
    echo "──────────────────────────────────"
}

cmd_list() {
    local mode="registry"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --installed) mode="installed"; shift ;;
            --profiles) mode="profiles"; shift ;;
            *) shift ;;
        esac
    done

    case "$mode" in
        registry)
            echo -e "${CYAN}Available Plugins${NC}"
            for plugin in "$REPO_DIR/dist/"*.plugin; do
                [[ -f "$plugin" ]] || continue
                local name=$(basename "$plugin" .plugin)
                local size=$(du -h "$plugin" | cut -f1)
                echo -e "  ${GREEN}$name${NC} ($size)"
            done
            ;;
        profiles)
            echo -e "${CYAN}Available Profiles${NC}"
            for pf in "$REPO_DIR/profiles/"*.txt; do
                [[ -f "$pf" ]] || continue
                echo -e "  ${GREEN}$(basename "$pf" .txt)${NC}"
            done
            ;;
    esac
}

cmd_init() {
    local profile=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}Usage: smorch init --profile <name>${NC}"
        return 1
    fi

    echo -e "${CYAN}smorch init — Team setup${NC}"
    cmd_pull --profile "$profile"
    echo -e "${GREEN}Setup complete! Point Cowork Desktop to: $REPO_DIR/plugins/${NC}"
}

case "${1:-}" in
    pull)       shift; cmd_pull "$@" ;;
    list)       shift; cmd_list "$@" ;;
    status)     cmd_status ;;
    init)       shift; cmd_init "$@" ;;
    --version)  echo "smorch v${VERSION}" ;;
    push|build-plugin|audit|compile)
        echo -e "${RED}Command '$1' is not available in the team edition.${NC}"
        echo -e "Contact Mamoun for source-level operations."
        ;;
    -h|--help|"") usage ;;
    *)  echo -e "${RED}Unknown command: $1${NC}"; usage ;;
esac
DISTCLI

chmod +x "$DIST_REPO/scripts/smorch"

# Copy install scripts
for script in smorch-install-plugins smorch-cleanup; do
    if [[ -f "$SOURCE_REPO/scripts/$script" ]]; then
        cp "$SOURCE_REPO/scripts/$script" "$DIST_REPO/scripts/"
        chmod +x "$DIST_REPO/scripts/$script"
    fi
done

# Copy MCP configs
if [[ -d "$SOURCE_REPO/mcp-configs" ]]; then
    cp -a "$SOURCE_REPO/mcp-configs" "$DIST_REPO/"
fi

# --- Step 4: Generate integrity manifest ---
echo -e "\n${CYAN}Step 4: Generating integrity manifest...${NC}"
{
    for plugin in "$DIST_REPO/dist/"*.plugin; do
        [[ -f "$plugin" ]] || continue
        shasum -a 256 "$plugin" | awk -v name="$(basename "$plugin")" '{print $1 "  " name}'
    done
} > "$DIST_REPO/dist/.manifest"
echo -e "  ${GREEN}Manifest: $(wc -l < "$DIST_REPO/dist/.manifest" | xargs) plugins hashed${NC}"

# --- Step 5: Commit and push ---
if [[ "$DRY_RUN" == true ]]; then
    echo -e "\n${YELLOW}DRY RUN complete. Output at: $DIST_REPO${NC}"
    echo -e "Files generated:"
    find "$DIST_REPO" -type f | head -30
else
    echo -e "\n${CYAN}Step 5: Committing to smorch-dist...${NC}"
    cd "$DIST_REPO"
    git add -A
    if git diff --cached --quiet; then
        echo -e "${YELLOW}No changes to publish.${NC}"
    else
        local_date=$(date -u +%Y-%m-%d)
        git commit -m "dist: compiled plugins published $local_date

Compiled from smorch-brain. Methodology stripped.
Watermarked. Integrity manifest updated."
        git push origin main 2>&1 && echo -e "${GREEN}Published to smorch-dist.${NC}" || {
            echo -e "${RED}Push failed. Check remote setup.${NC}"
        }
    fi
fi

# Cleanup
rm -rf "$TEMP_DIR"

echo -e "\n${GREEN}╔══════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║  Distribution published successfully     ║${NC}"
echo -e "${GREEN}╚══════════════════════════════════════════╝${NC}"
echo -e "Team runs: git -C $DIST_REPO pull && smorch pull --profile <name>"
