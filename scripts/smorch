#!/usr/bin/env bash
set -euo pipefail

# smorch — SMOrchestra Skill Registry CLI
# Single tool for managing skills across all nodes
# Repo: github.com/SMOrchestra-ai/smorch-brain

VERSION="2.0.0"
REPO_DIR="$HOME/smorch-brain"
SKILLS_TARGET="$HOME/.claude/skills"
MCP_TARGET="$HOME/.claude/.mcp.json"
STATE_FILE="$REPO_DIR/.smorch-state"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    cat <<EOF
smorch v${VERSION} — SMOrchestra Skill Registry

Usage: smorch <command> [options]

Commands:
  push                    Export Cowork skills to registry + git push
  pull                    Git pull + install current profile's skills
  pull --profile <name>   Pull + install specific profile (saves as default)
  install <path>          Install a category or single skill
  remove <path>           Remove a category or skill from this machine
  list                    Show all skills in registry (by category)
  list --installed        Show skills installed on this machine
  list --available        Show skills in registry but NOT installed
  list --profiles         Show available profiles
  diff                    Show what changed since last pull
  status                  Profile, last sync, skill counts
  init --profile <name>   First-time setup on a new machine
  audit                   Check for issues (unmapped, oversized, missing versions)
  build-plugin <name>     Build .plugin zip from plugins/<name>/

Registry: ${REPO_DIR}
Skills:   ${SKILLS_TARGET}
EOF
}

# Load state (current profile, last sync timestamp)
load_state() {
    CURRENT_PROFILE=""
    LAST_SYNC=""
    if [[ -f "$STATE_FILE" ]]; then
        source "$STATE_FILE"
    fi
}

save_state() {
    cat > "$STATE_FILE" <<EOF
CURRENT_PROFILE="${CURRENT_PROFILE}"
LAST_SYNC="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
EOF
}

# Resolve profile lines to actual skill directories
# Handles: *, category/*, category/specific-skill
resolve_profile() {
    local profile_file="$REPO_DIR/profiles/$1.txt"
    if [[ ! -f "$profile_file" ]]; then
        echo -e "${RED}ERROR: Profile '$1' not found at $profile_file${NC}" >&2
        return 1
    fi

    local skills=()
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip comments and empty lines
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        line=$(echo "$line" | xargs)  # trim whitespace

        if [[ "$line" == "*" ]]; then
            # All skills
            for cat_dir in "$REPO_DIR/skills"/*/; do
                for skill_dir in "$cat_dir"*/; do
                    [[ -d "$skill_dir" ]] && skills+=("${skill_dir#$REPO_DIR/skills/}")
                done
            done
        elif [[ "$line" == *"/*" ]]; then
            # Category wildcard: eo-training/*
            local category="${line%/*}"
            for skill_dir in "$REPO_DIR/skills/$category"/*/; do
                [[ -d "$skill_dir" ]] && skills+=("${skill_dir#$REPO_DIR/skills/}")
            done
        else
            # Specific skill: dev-meta/systematic-debugging
            if [[ -d "$REPO_DIR/skills/$line" ]]; then
                skills+=("$line/")
            else
                echo -e "${YELLOW}WARN: Skill '$line' not found in registry${NC}" >&2
            fi
        fi
    done < "$profile_file"

    printf '%s\n' "${skills[@]}"
}

cmd_push() {
    echo -e "${CYAN}smorch push — Exporting skills to registry${NC}"

    # Primary skills directory (symlinked to cowork-workspace/SKILLs/)
    local skills_path="$HOME/.claude/skills"
    if [[ ! -d "$skills_path" ]]; then
        echo -e "${RED}ERROR: ~/.claude/skills not found${NC}"
        return 1
    fi

    # --- Phase 0: Pull new CUSTOM skills from Cowork Desktop sessions ---
    # Only pulls skills user manually added (customize → skills → add)
    # Does NOT pull plugin skills (those stay in PLUGINS/ only)
    local sessions_base="$HOME/Library/Application Support/Claude/local-agent-mode-sessions"
    if [[ -d "$sessions_base" ]]; then
        local pulled=0
        while IFS= read -r -d '' skill_dir; do
            local skill_name
            skill_name=$(basename "$skill_dir")
            # Skip if already exists
            [[ -d "$skills_path/$skill_name" ]] && continue
            # Skip Anthropic built-ins
            case "$skill_name" in
                algorithmic-art|brand-guidelines|canvas-design|doc-coauthoring|docx|internal-comms|mcp-builder|pdf|pptx|schedule|skill-creator|theme-factory|web-artifacts-builder|xlsx) continue ;;
            esac
            # Check manifest — skip if Anthropic-created
            local manifest="$skill_dir/manifest.json"
            if [[ -f "$manifest" ]]; then
                local ctype
                ctype=$(python3 -c "import json; print(json.load(open('$manifest')).get('creatorType',''))" 2>/dev/null || echo "")
                [[ "$ctype" == "anthropic" ]] && continue
            fi
            cp -a "$skill_dir" "$skills_path/$skill_name"
            chmod -R u+w "$skills_path/$skill_name" 2>/dev/null
            echo -e "  ${GREEN}+${NC} Pulled from Cowork: $skill_name"
            pulled=$((pulled + 1))
        done < <(find "$sessions_base" -path "*/.claude/skills/*" -maxdepth 7 -mindepth 7 -type d -print0 2>/dev/null)
        [[ $pulled -gt 0 ]] && echo -e "${GREEN}Pulled $pulled new skills from Cowork Desktop${NC}"
    fi

    # --- Phase 0b: Sync Cowork plugins → PLUGINS/ (full packages, no skills into SKILLs) ---
    local workspace_plugins="$HOME/Desktop/cowork-workspace/PLUGINS"
    if [[ -d "$sessions_base" ]]; then
        local plugins_cache=""
        while IFS= read -r -d '' candidate; do
            plugins_cache="$candidate"
            break
        done < <(find "$sessions_base" -path "*/cowork_plugins/cache" -type d -print0 2>/dev/null)
        if [[ -n "$plugins_cache" && -d "$workspace_plugins" ]]; then
            local psync=0
            # knowledge-work-plugins (latest version each)
            for pdir in "$plugins_cache"/knowledge-work-plugins/*/; do
                [[ -d "$pdir" ]] || continue
                local pname=$(basename "$pdir")
                local latest=$(ls "$pdir" | sort -V | tail -1)
                local src="$pdir$latest"
                local dest="$workspace_plugins/$pname"
                if [[ -d "$src" ]] && [[ ! -d "$dest" || "$src" -nt "$dest" ]]; then
                    rm -rf "$dest" 2>/dev/null
                    cp -a "$src" "$dest"
                    chmod -R u+w "$dest" 2>/dev/null
                    psync=$((psync + 1))
                fi
            done
            # local-desktop-app-uploads
            for pdir in "$plugins_cache"/local-desktop-app-uploads/*/; do
                [[ -d "$pdir" ]] || continue
                local pname=$(basename "$pdir")
                local latest=$(ls "$pdir" | sort -V | tail -1)
                local src="$pdir$latest"
                local dest="$workspace_plugins/$pname"
                if [[ -d "$src" ]] && [[ ! -d "$dest" || "$src" -nt "$dest" ]]; then
                    rm -rf "$dest" 2>/dev/null
                    cp -a "$src" "$dest"
                    chmod -R u+w "$dest" 2>/dev/null
                    psync=$((psync + 1))
                fi
            done
            [[ $psync -gt 0 ]] && echo -e "${GREEN}Synced $psync plugins to PLUGINS/${NC}"
        fi
    fi

    echo -e "Skills dir: ${GREEN}$skills_path${NC} ($(find "$skills_path" -maxdepth 1 -mindepth 1 -type d | wc -l | xargs) skills)"

    # Files to exclude from export (bloat reduction)
    local -a EXCLUDE_FILES=(
        "package-lock.json" "*.html" "*.ttf" "*.woff" "*.woff2"
        "*.png" "*.jpg" "*.jpeg" "*.gif" "*.svg" "*.ico"
        "node_modules" "__pycache__" ".DS_Store"
    )

    # Anthropic built-in skills to skip
    local -a SKIP=(
        algorithmic-art brand-guidelines canvas-design doc-coauthoring
        docx internal-comms mcp-builder pdf pptx schedule
        skill-creator theme-factory web-artifacts-builder xlsx
    )

    # Category mapping: reads .smorch-category file first, falls back to hardcoded map
    get_category() {
        local skill_path="$skills_path/$1"
        # Priority 1: .smorch-category file in skill directory
        if [[ -f "$skill_path/.smorch-category" ]]; then
            cat "$skill_path/.smorch-category" | xargs
            return
        fi
        # Priority 2: Hardcoded fallback map
        case "$1" in
            signal-to-trust-gtm|signal-detector|wedge-generator|asset-factory|campaign-strategist) echo "smorch-gtm" ;;
            positioning-engine|outbound-orchestrator|ghl-operator|instantly-operator|heyreach-operator) echo "smorch-gtm" ;;
            clay-operator|n8n-architect|scraper-layer|smorch-salesnav-operator|smorch-linkedin-intel) echo "smorch-gtm" ;;
            eo-brain-ingestion|eo-gtm-asset-factory|eo-gtm-asset-builder|eo-skill-extractor|eo-tech-architect|eo-microsaas-dev) echo "eo-training" ;;
            eo-db-architect|eo-api-connector|eo-qa-testing|eo-security-hardener|eo-deploy-infra|eo-training-factory) echo "eo-training" ;;
            eo-production-renderer|eo-guide|eo-os-navigator) echo "eo-training" ;;
            project-definition-scoring-engine|icp-clarity-scoring-engine|market-attractiveness-scoring-engine) echo "eo-scoring" ;;
            strategy-selector-engine|gtm-fitness-scoring-engine) echo "eo-scoring" ;;
            eo-youtube-mamoun|smorch-perfect-webinar|smo-offer-assets|content-systems|movement-builder) echo "content" ;;
            engagement-engine|validation-sprint|arabic-localizer) echo "content" ;;
            smo-skill-creator|smorch-tool-super-admin-creator|systematic-debugging|smorch-github-ops|changelog-generator) echo "dev-meta" ;;
            requesting-code-review|receiving-code-review|using-superpowers) echo "dev-meta" ;;
            frontend-design|webapp-testing|get-api-docs|lead-research-assistant|saasfast-gating) echo "tools" ;;
            client-onboarding|contabo-deployment|supabase-admin) echo "tools" ;;
            smorch-about-me|smorch-project-brain) echo "personal" ;;
            *) echo "" ;;
        esac
    }

    # Create category directories
    for cat in smorch-gtm eo-training eo-scoring content dev-meta tools personal; do
        mkdir -p "$REPO_DIR/skills/$cat"
    done

    local copied=0
    local skipped=0
    local oversized=0
    for skill_dir in "$skills_path"/*/; do
        local skill_name
        skill_name=$(basename "$skill_dir")

        # Check manifest for creatorType
        local manifest="$skill_dir/manifest.json"
        if [[ -f "$manifest" ]]; then
            local creator_type
            creator_type=$(python3 -c "import json; print(json.load(open('$manifest')).get('creatorType',''))" 2>/dev/null || echo "")
            if [[ "$creator_type" == "anthropic" ]]; then
                skipped=$((skipped + 1))
                continue
            fi
        fi

        # Skip known Anthropic skills by name
        local is_skip=false
        for s in "${SKIP[@]}"; do
            [[ "$skill_name" == "$s" ]] && { is_skip=true; break; }
        done
        [[ "$is_skip" == true ]] && { skipped=$((skipped + 1)); continue; }

        # Find category
        local category
        category=$(get_category "$skill_name")
        if [[ -z "$category" ]]; then
            echo -e "${YELLOW}UNMAPPED: $skill_name — add .smorch-category file or update get_category()${NC}"
            skipped=$((skipped + 1))
            continue
        fi

        # Flag oversized SKILL.md (>20KB should use references instead)
        local skill_md="$skill_dir/SKILL.md"
        if [[ -f "$skill_md" ]]; then
            local size
            size=$(wc -c < "$skill_md" | xargs)
            if [[ $size -gt 20480 ]]; then
                echo -e "${YELLOW}LARGE: $skill_name/SKILL.md ($(( size / 1024 ))KB) — consider using reference files${NC}"
                oversized=$((oversized + 1))
            fi
        fi

        # Copy skill, excluding bloat files
        local dest="$REPO_DIR/skills/$category/$skill_name"
        mkdir -p "$dest"
        # Use rsync for selective copy with excludes
        local exclude_args=""
        for ex in "${EXCLUDE_FILES[@]}"; do
            exclude_args="$exclude_args --exclude=$ex"
        done
        rsync -a $exclude_args "$skill_dir/" "$dest/"
        copied=$((copied + 1))
    done

    echo -e "${GREEN}Exported: $copied skills | Skipped: $skipped Anthropic built-ins${NC}"
    [[ $oversized -gt 0 ]] && echo -e "${YELLOW}$oversized skill(s) over 20KB — consider splitting into reference files${NC}"

    # Git operations
    cd "$REPO_DIR"
    git add skills/
    if git diff --cached --quiet; then
        echo -e "${YELLOW}No changes to commit.${NC}"
    else
        local changes
        changes=$(git diff --cached --stat | tail -1)
        git commit -m "skills: export from Cowork — $changes"
        echo -e "${GREEN}Committed.${NC}"
        # Push to dev first (safe — no branch protection bypass needed)
        git push origin dev 2>&1 && echo -e "${GREEN}Pushed to dev.${NC}" || {
            # If dev doesn't exist locally, create it tracking origin/dev
            git checkout -b dev origin/dev 2>/dev/null || git checkout dev 2>/dev/null
            git merge main --no-edit 2>/dev/null
            git push origin dev 2>&1 && echo -e "${GREEN}Pushed to dev.${NC}"
        }
        # Skills go to dev. Mamoun promotes dev → main via release PR when ready.
        echo -e "${CYAN}Skills pushed to dev branch. Run 'smorch release' to promote to main via PR.${NC}"
    fi
}

cmd_pull() {
    load_state
    local profile="${CURRENT_PROFILE}"

    # Parse --profile flag
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            *) echo "Unknown option: $1"; return 1 ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}ERROR: No profile set. Run: smorch pull --profile <name>${NC}"
        echo "Available profiles:"
        ls "$REPO_DIR/profiles/"*.txt 2>/dev/null | xargs -I{} basename {} .txt | sed 's/^/  /'
        return 1
    fi

    echo -e "${CYAN}smorch pull — Syncing profile: $profile${NC}"

    # Git pull
    cd "$REPO_DIR"
    echo "Pulling latest from GitHub..."
    git pull --rebase origin main 2>&1 || {
        echo -e "${RED}Git pull failed. Resolve conflicts manually.${NC}"
        return 1
    }

    # Backup current skills
    if [[ -d "$SKILLS_TARGET" ]] && [[ "$(ls -A "$SKILLS_TARGET" 2>/dev/null)" ]]; then
        local backup_dir="$HOME/.claude/skills.bak.$(date +%Y%m%d%H%M%S)"
        cp -a "$SKILLS_TARGET" "$backup_dir"
        echo -e "Backup: ${YELLOW}$backup_dir${NC}"
    fi

    # Clean only managed categories (preserve Anthropic/system skills)
    local -a MANAGED_CATS=(smorch-gtm eo-training eo-scoring content dev-meta tools personal)
    for cat in "${MANAGED_CATS[@]}"; do
        rm -rf "$SKILLS_TARGET/$cat" 2>/dev/null
    done
    mkdir -p "$SKILLS_TARGET"

    local count=0
    while IFS= read -r skill_path; do
        [[ -z "$skill_path" ]] && continue
        skill_path="${skill_path%/}"  # Remove trailing slash
        local category="${skill_path%%/*}"
        local skill_name="${skill_path#*/}"
        skill_name="${skill_name%/}"

        mkdir -p "$SKILLS_TARGET/$category"
        cp -a "$REPO_DIR/skills/$skill_path" "$SKILLS_TARGET/$category/$skill_name"
        count=$((count + 1))
    done < <(resolve_profile "$profile")

    # Install MCP config
    local base_mcp="$REPO_DIR/mcp-configs/base.mcp.json"
    local overlay_name="${profile%-agent}"  # smo-brain-agent -> smo-brain, mamoun -> mamoun
    [[ "$overlay_name" == "mamoun" ]] && overlay_name="desktop"
    local overlay_mcp="$REPO_DIR/mcp-configs/$overlay_name.mcp.json"

    if [[ -f "$base_mcp" ]]; then
        if [[ -f "$overlay_mcp" ]] && command -v jq &>/dev/null; then
            jq -s '.[0].mcpServers * .[1].mcpServers | {mcpServers: .}' "$base_mcp" "$overlay_mcp" > "$MCP_TARGET"
            echo -e "MCP: merged base + $overlay_name"
        else
            cp "$base_mcp" "$MCP_TARGET"
            echo -e "MCP: base only (no overlay or jq)"
        fi
    fi

    # Copy CLAUDE.md if exists
    if [[ -f "$REPO_DIR/CLAUDE.md" ]]; then
        cp "$REPO_DIR/CLAUDE.md" "$HOME/.claude/CLAUDE.md"
    fi

    # Save state
    CURRENT_PROFILE="$profile"
    save_state

    echo -e "${GREEN}Installed $count skills (profile: $profile)${NC}"
}

cmd_install() {
    local target="$1"

    if [[ -z "$target" ]]; then
        echo -e "${RED}Usage: smorch install <category> or smorch install <category/skill>${NC}"
        return 1
    fi

    cd "$REPO_DIR"
    git pull --rebase origin main 2>&1 >/dev/null

    if [[ -d "$REPO_DIR/skills/$target" ]]; then
        if [[ "$target" == *"/"* ]]; then
            # Single skill: eo-training/eo-brain-ingestion
            local category="${target%%/*}"
            mkdir -p "$SKILLS_TARGET/$category"
            cp -a "$REPO_DIR/skills/$target" "$SKILLS_TARGET/$target"
            echo -e "${GREEN}Installed: $target${NC}"
        else
            # Category: eo-training (copy all skills in it)
            mkdir -p "$SKILLS_TARGET/$target"
            local count=0
            for skill_dir in "$REPO_DIR/skills/$target"/*/; do
                [[ -d "$skill_dir" ]] || continue
                cp -a "$skill_dir" "$SKILLS_TARGET/$target/"
                count=$((count + 1))
            done
            echo -e "${GREEN}Installed: $target ($count skills)${NC}"
        fi
    else
        echo -e "${RED}Not found in registry: $target${NC}"
        echo "Available categories:"
        ls "$REPO_DIR/skills/" | sed 's/^/  /'
        return 1
    fi
}

cmd_remove() {
    local target="$1"
    if [[ -z "$target" ]]; then
        echo -e "${RED}Usage: smorch remove <category> or smorch remove <category/skill>${NC}"
        return 1
    fi

    if [[ -d "$SKILLS_TARGET/$target" ]]; then
        rm -rf "$SKILLS_TARGET/$target"
        echo -e "${GREEN}Removed: $target${NC}"
    else
        echo -e "${RED}Not installed: $target${NC}"
        return 1
    fi
}

cmd_list() {
    local mode="registry"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --installed) mode="installed"; shift ;;
            --available) mode="available"; shift ;;
            --profiles) mode="profiles"; shift ;;
            *) shift ;;
        esac
    done

    case "$mode" in
        registry)
            echo -e "${CYAN}Skills Registry (smorch-brain)${NC}"
            for cat_dir in "$REPO_DIR/skills"/*/; do
                [[ -d "$cat_dir" ]] || continue
                local cat_name
                cat_name=$(basename "$cat_dir")
                local count
                count=$(find "$cat_dir" -maxdepth 1 -mindepth 1 -type d | wc -l | xargs)
                echo -e "\n${GREEN}$cat_name/ ($count skills)${NC}"
                for skill_dir in "$cat_dir"*/; do
                    [[ -d "$skill_dir" ]] || continue
                    echo "  $(basename "$skill_dir")"
                done
            done
            ;;
        installed)
            echo -e "${CYAN}Installed Skills ($SKILLS_TARGET)${NC}"
            if [[ ! -d "$SKILLS_TARGET" ]]; then
                echo "  (none)"
                return
            fi
            local total=0
            for cat_dir in "$SKILLS_TARGET"/*/; do
                [[ -d "$cat_dir" ]] || continue
                local cat_name
                cat_name=$(basename "$cat_dir")
                local count
                count=$(find "$cat_dir" -maxdepth 1 -mindepth 1 -type d | wc -l | xargs)
                total=$((total + count))
                echo -e "\n${GREEN}$cat_name/ ($count skills)${NC}"
                for skill_dir in "$cat_dir"*/; do
                    [[ -d "$skill_dir" ]] || continue
                    echo "  $(basename "$skill_dir")"
                done
            done
            echo -e "\n${CYAN}Total: $total skills${NC}"
            ;;
        available)
            echo -e "${CYAN}Available but NOT installed${NC}"
            for cat_dir in "$REPO_DIR/skills"/*/; do
                [[ -d "$cat_dir" ]] || continue
                local cat_name
                cat_name=$(basename "$cat_dir")
                for skill_dir in "$cat_dir"*/; do
                    [[ -d "$skill_dir" ]] || continue
                    local skill_name
                    skill_name=$(basename "$skill_dir")
                    if [[ ! -d "$SKILLS_TARGET/$cat_name/$skill_name" ]]; then
                        echo "  $cat_name/$skill_name"
                    fi
                done
            done
            ;;
        profiles)
            echo -e "${CYAN}Available Profiles${NC}"
            for pf in "$REPO_DIR/profiles/"*.txt; do
                [[ -f "$pf" ]] || continue
                local name
                name=$(basename "$pf" .txt)
                local count
                count=$(resolve_profile "$name" 2>/dev/null | wc -l | xargs)
                echo -e "  ${GREEN}$name${NC} ($count skills)"
            done
            ;;
    esac
}

cmd_diff() {
    cd "$REPO_DIR"
    git fetch origin main 2>/dev/null
    local diff_output
    diff_output=$(git diff HEAD..origin/main --stat -- skills/ 2>/dev/null)
    if [[ -z "$diff_output" ]]; then
        echo -e "${GREEN}No changes since last pull.${NC}"
    else
        echo -e "${CYAN}Changes on GitHub since last pull:${NC}"
        echo "$diff_output"
    fi
}

cmd_status() {
    load_state
    echo -e "${CYAN}smorch status${NC}"
    echo "──────────────────────────────────"
    echo -e "Profile:    ${GREEN}${CURRENT_PROFILE:-<not set>}${NC}"
    echo -e "Last sync:  ${LAST_SYNC:-never}"
    echo -e "Registry:   $REPO_DIR"
    echo -e "Skills dir: $SKILLS_TARGET"

    # Count installed
    if [[ -d "$SKILLS_TARGET" ]]; then
        local installed
        installed=$(find "$SKILLS_TARGET" -maxdepth 2 -mindepth 2 -type d | wc -l | xargs)
        echo -e "Installed:  ${GREEN}$installed skills${NC}"
    else
        echo -e "Installed:  ${RED}0 (no skills dir)${NC}"
    fi

    # Count in registry
    local registry_count
    registry_count=$(find "$REPO_DIR/skills" -maxdepth 2 -mindepth 2 -type d 2>/dev/null | wc -l | xargs)
    echo -e "Registry:   $registry_count skills"

    # Git status
    cd "$REPO_DIR" 2>/dev/null
    local branch
    branch=$(git branch --show-current 2>/dev/null)
    local behind
    behind=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo "?")
    echo -e "Git branch: $branch (${behind} commits behind)"
    echo "──────────────────────────────────"
}

cmd_init() {
    local profile=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --profile) profile="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [[ -z "$profile" ]]; then
        echo -e "${RED}Usage: smorch init --profile <name>${NC}"
        echo "Available profiles:"
        ls "$REPO_DIR/profiles/"*.txt 2>/dev/null | xargs -I{} basename {} .txt | sed 's/^/  /'
        return 1
    fi

    echo -e "${CYAN}smorch init — First-time setup${NC}"

    # Ensure repo is cloned
    if [[ ! -d "$REPO_DIR" ]]; then
        echo "Cloning smorch-brain..."
        git clone git@github.com:SMOrchestra-ai/smorch-brain.git "$REPO_DIR"
    fi

    # Pull and install
    cmd_pull --profile "$profile"

    echo -e "${GREEN}Setup complete! Run 'smorch status' to verify.${NC}"
}

cmd_audit() {
    echo -e "${CYAN}smorch audit — Checking for issues${NC}"
    echo "──────────────────────────────────"
    local issues=0

    # 1. Unmapped skills (no .smorch-category and not in hardcoded map)
    local skills_path="$HOME/.claude/skills"
    if [[ -d "$skills_path" ]]; then
        echo -e "\n${CYAN}Checking for unmapped skills...${NC}"
        for skill_dir in "$skills_path"/*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            # Skip category dirs and known system dirs
            [[ -d "$skill_dir/SKILL.md" ]] || [[ -f "$skill_dir/SKILL.md" ]] || continue
            if [[ ! -f "$skill_dir/.smorch-category" ]]; then
                echo -e "  ${YELLOW}UNMAPPED: $skill_name — missing .smorch-category file${NC}"
                issues=$((issues + 1))
            fi
        done
    fi

    # 2. Missing version files
    echo -e "\n${CYAN}Checking for missing version files...${NC}"
    if [[ -d "$skills_path" ]]; then
        for skill_dir in "$skills_path"/*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            [[ -f "$skill_dir/SKILL.md" ]] || continue
            if [[ ! -f "$skill_dir/.smorch-version" ]]; then
                echo -e "  ${YELLOW}NO VERSION: $skill_name — missing .smorch-version file${NC}"
                issues=$((issues + 1))
            fi
        done
    fi

    # 3. Oversized SKILL.md files (>500 lines)
    echo -e "\n${CYAN}Checking for oversized SKILL.md files (>500 lines)...${NC}"
    while IFS= read -r line; do
        local linecount="${line%% *}"
        local filepath="${line#* }"
        if [[ "$linecount" -gt 500 ]]; then
            echo -e "  ${RED}OVERSIZED: $filepath ($linecount lines, limit: 500)${NC}"
            issues=$((issues + 1))
        fi
    done < <(find "$skills_path" "$REPO_DIR/plugins" -name "SKILL.md" -exec sh -c 'echo "$(wc -l < "$1") $1"' _ {} \; 2>/dev/null | sort -rn)

    # 4. Skills not in any profile
    echo -e "\n${CYAN}Checking for skills not in any profile...${NC}"
    for cat_dir in "$REPO_DIR/skills"/*/; do
        [[ -d "$cat_dir" ]] || continue
        local cat_name
        cat_name=$(basename "$cat_dir")
        for skill_dir in "$cat_dir"*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name=$(basename "$skill_dir")
            local in_profile=false
            for pf in "$REPO_DIR/profiles/"*.txt; do
                if grep -q "$cat_name/\*\|$cat_name/$skill_name\|^\*$" "$pf" 2>/dev/null; then
                    in_profile=true
                    break
                fi
            done
            if [[ "$in_profile" == false ]]; then
                echo -e "  ${YELLOW}ORPHAN: $cat_name/$skill_name — not in any profile${NC}"
                issues=$((issues + 1))
            fi
        done
    done

    echo -e "\n──────────────────────────────────"
    if [[ $issues -eq 0 ]]; then
        echo -e "${GREEN}All clear! No issues found.${NC}"
    else
        echo -e "${RED}Found $issues issue(s) to fix.${NC}"
    fi
}

cmd_build_plugin() {
    local plugin_name="$1"
    if [[ -z "$plugin_name" ]]; then
        echo -e "${RED}Usage: smorch build-plugin <name>${NC}"
        echo "Available plugins:"
        ls "$REPO_DIR/plugins/" 2>/dev/null | sed 's/^/  /'
        return 1
    fi

    local plugin_dir="$REPO_DIR/plugins/$plugin_name"
    if [[ ! -d "$plugin_dir" ]]; then
        echo -e "${RED}Plugin not found: $plugin_dir${NC}"
        return 1
    fi

    local output="$REPO_DIR/dist/${plugin_name}.plugin"
    mkdir -p "$REPO_DIR/dist"

    echo -e "${CYAN}Building plugin: $plugin_name${NC}"

    # Create zip (excluding .DS_Store, node_modules, etc.)
    cd "$plugin_dir"
    zip -r "$output" . \
        -x "*.DS_Store" \
        -x "*node_modules/*" \
        -x "*__pycache__/*" \
        -x "*.git/*" \
        2>/dev/null

    local size
    size=$(du -h "$output" | cut -f1)
    echo -e "${GREEN}Built: $output ($size)${NC}"
    echo -e "To install: Upload via Cowork > Customize > Plugins"
}

# Main dispatch
case "${1:-}" in
    push)       cmd_push ;;
    pull)       shift; cmd_pull "$@" ;;
    install)    shift; cmd_install "$@" ;;
    remove)     shift; cmd_remove "$@" ;;
    list)       shift; cmd_list "$@" ;;
    diff)       cmd_diff ;;
    status)     cmd_status ;;
    init)       shift; cmd_init "$@" ;;
    audit)      cmd_audit ;;
    build-plugin) shift; cmd_build_plugin "$@" ;;
    --version)  echo "smorch v${VERSION}" ;;
    -h|--help|"") usage ;;
    *)          echo "Unknown command: $1"; usage; exit 1 ;;
esac
