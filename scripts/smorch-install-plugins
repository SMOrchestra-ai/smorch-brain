#!/usr/bin/env bash
set -euo pipefail

# smorch-install-plugins — Install plugins for your role
# Works on: macOS, Linux
# Usage: smorch-install-plugins --role <gtm|dev|eo-student|mamoun>

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

show_help() {
    echo "smorch-install-plugins — Install the right plugins for your role"
    echo ""
    echo "BY ROLE (recommended):"
    echo "  --role gtm          GTM team: all Code plugins + shows Cowork plugin list"
    echo "  --role dev          Dev team: official Code plugins + shows Cowork plugin list"
    echo "  --role eo-student   EO student: official Code plugins + shows Cowork plugin list"
    echo "  --role mamoun       Everything"
    echo ""
    echo "MANUAL (pick what you want):"
    echo "  --all               All Claude Code plugins (official + GTM agents)"
    echo "  --official          Official Anthropic only (LSPs + code-review + frontend + github)"
    echo "  --lsp               Language servers only (typescript, python, rust, go)"
    echo "  --gtm               GTM agent plugins only"
    echo ""
    echo "INDIVIDUAL:"
    echo "  --typescript --python --rust --go --code-review --frontend --github"
    echo ""
    echo "INFO:"
    echo "  --list-cowork       Show Cowork-only plugins per role"
    echo "  --help              This help"
}

install_plugin() {
    local name="$1"
    local registry="$2"
    echo -e "${BLUE}Installing${NC} ${name}@${registry}..."
    if claude /plugin install "${name}@${registry}" 2>/dev/null; then
        echo -e "${GREEN}  OK${NC}"
    else
        echo -e "${YELLOW}  SKIP${NC} (already installed or unavailable)"
    fi
}

install_official() {
    echo -e "${CYAN}=== Official Anthropic Plugins (7) ===${NC}"
    for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp code-review frontend-design github; do
        install_plugin "$p" "claude-plugins-official"
    done
}

install_gtm_agents() {
    echo -e "${CYAN}=== GTM Agent Plugins (9) ===${NC}"
    for p in campaign-orchestration content-marketing customer-analytics email-marketing growth-experiments revenue-analytics sales-enablement sales-pipeline sales-prospecting; do
        install_plugin "$p" "gtm-agents"
    done
}

show_cowork_gtm() {
    echo ""
    echo -e "${CYAN}=== NOW: Install these in Cowork Desktop ===${NC}"
    echo -e "${CYAN}   Go to: Customize > Plugins > Search marketplace${NC}"
    echo ""
    echo "  1. smorch-context-brain     — Project brain builder, about-me files"
    echo "  2. smorch-gtm-tools         — Clay, GHL, Instantly, HeyReach, SalesNav"
    echo "  3. smorch-gtm-engine        — Campaigns, signals, wedges, outbound"
    echo "  4. smorch-design            — Frontend design, brand system, canvas art"
    echo "  5. mamoun-personal-branding — LinkedIn writer, YouTube decks, content"
}

show_cowork_dev() {
    echo ""
    echo -e "${CYAN}=== NOW: Install this in Cowork Desktop ===${NC}"
    echo -e "${CYAN}   Go to: Customize > Plugins > Search marketplace${NC}"
    echo ""
    echo "  1. smorch-dev — Debugging, code review, MCP builder, n8n, validation, API docs"
}

show_cowork_eo() {
    echo ""
    echo -e "${CYAN}=== NOW: Install these in Cowork Desktop ===${NC}"
    echo -e "${CYAN}   Go to: Customize > Plugins > Search marketplace${NC}"
    echo ""
    echo "  1. eo-microsaas-os — Full MicroSaaS journey (scorecards, brain, dev, deploy)"
    echo "  2. smorch-dev      — Debugging, code review, MCP builder, testing"
}

MODE="${1:---help}"

case "$MODE" in
    --help|-h)
        show_help
        exit 0
        ;;
    --role)
        ROLE="${2:-}"
        case "$ROLE" in
            gtm)
                echo -e "${GREEN}=== GTM Team Setup ===${NC}"
                echo "Installing: 7 official + 9 GTM agent plugins (Claude Code only)"
                echo ""
                install_official
                echo ""
                install_gtm_agents
                show_cowork_gtm
                ;;
            dev)
                echo -e "${GREEN}=== Dev Team Setup ===${NC}"
                echo "Installing: 7 official plugins (Claude Code only)"
                echo ""
                install_official
                echo ""
                echo -e "${YELLOW}NOTE: GTM agent plugins not included for dev role.${NC}"
                show_cowork_dev
                ;;
            eo-student)
                echo -e "${GREEN}=== EO Student Setup ===${NC}"
                echo "Installing: 7 official plugins (Claude Code only)"
                echo ""
                install_official
                echo ""
                echo -e "${YELLOW}NOTE: GTM agent plugins not included for students.${NC}"
                show_cowork_eo
                ;;
            mamoun)
                echo -e "${GREEN}=== Mamoun (All Access) ===${NC}"
                install_official
                echo ""
                install_gtm_agents
                echo ""
                echo -e "${CYAN}All Cowork plugins should already be installed.${NC}"
                ;;
            *)
                echo "Unknown role: $ROLE"
                echo "Available: gtm, dev, eo-student, mamoun"
                exit 1
                ;;
        esac
        ;;
    --list-cowork)
        echo -e "${CYAN}=== Cowork Plugins by Role ===${NC}"
        echo ""
        echo "GTM Team (5 plugins):"
        echo "  smorch-context-brain, smorch-gtm-tools, smorch-gtm-engine,"
        echo "  smorch-design, mamoun-personal-branding"
        echo ""
        echo "Dev Team (1 plugin):"
        echo "  smorch-dev"
        echo ""
        echo "EO Student (2 plugins):"
        echo "  eo-microsaas-os, smorch-dev"
        echo ""
        echo "Install via: Cowork > Customize > Plugins > Search marketplace"
        exit 0
        ;;
    --lsp)
        echo -e "${GREEN}Installing LSP plugins...${NC}"
        for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp; do
            install_plugin "$p" "claude-plugins-official"
        done
        ;;
    --official)
        install_official
        ;;
    --gtm)
        install_gtm_agents
        ;;
    --all)
        install_official
        echo ""
        install_gtm_agents
        ;;
    --typescript) install_plugin "typescript-lsp" "claude-plugins-official" ;;
    --python) install_plugin "pyright-lsp" "claude-plugins-official" ;;
    --rust) install_plugin "rust-analyzer-lsp" "claude-plugins-official" ;;
    --go) install_plugin "gopls-lsp" "claude-plugins-official" ;;
    --code-review) install_plugin "code-review" "claude-plugins-official" ;;
    --frontend) install_plugin "frontend-design" "claude-plugins-official" ;;
    --github) install_plugin "github" "claude-plugins-official" ;;
    *)
        echo "Unknown option: $MODE"
        show_help
        exit 1
        ;;
esac

echo ""
echo -e "${GREEN}Done!${NC} Restart Claude Code to activate new plugins."
