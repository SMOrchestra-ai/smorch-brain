#!/usr/bin/env bash
set -euo pipefail

# smorch-install-plugins — Install Claude Code plugins (CLI-only, not Cowork)
# Works on: macOS, Linux
# Usage: smorch-install-plugins [--all | --lsp | --gtm | --official | --list-cowork]

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

show_help() {
    echo "smorch-install-plugins — Install Claude Code plugins"
    echo ""
    echo "Usage: smorch-install-plugins [OPTIONS]"
    echo ""
    echo "Claude Code Only (these are NOT in Cowork):"
    echo "  --all         Install all Claude Code plugins (default)"
    echo "  --lsp         Install language server plugins only (dev team)"
    echo "  --official    Install official Anthropic plugins only"
    echo "  --gtm         Install GTM agents plugins only"
    echo ""
    echo "Individual Claude Code plugins:"
    echo "  --typescript   TypeScript/JavaScript LSP"
    echo "  --python       Python (Pyright) LSP"
    echo "  --rust         Rust Analyzer LSP"
    echo "  --go           Go (gopls) LSP"
    echo "  --code-review  Code review plugin"
    echo "  --frontend     Frontend design plugin"
    echo "  --github       GitHub integration plugin"
    echo ""
    echo "Info:"
    echo "  --list-cowork  Show Cowork-only plugins (install via Desktop app)"
    echo "  --help         Show this help"
    echo ""
    echo "Cowork plugins are installed via Desktop app (Customize > Plugins)."
    echo "Use --list-cowork to see which plugins are Cowork-only."
}

install_plugin() {
    local name="$1"
    local registry="$2"
    echo -e "${BLUE}Installing${NC} ${name}@${registry}..."
    if claude /plugin install "${name}@${registry}" 2>/dev/null; then
        echo -e "${GREEN}  OK${NC}"
    else
        echo -e "${YELLOW}  SKIP${NC} (already installed or unavailable)"
    fi
}

list_cowork() {
    echo -e "${CYAN}=== Cowork-Only Plugins (install via Claude Desktop > Customize > Plugins) ===${NC}"
    echo ""
    echo "These 9 plugins are available ONLY in Cowork Desktop."
    echo "They are NOT installable via Claude Code CLI."
    echo ""
    echo "  Plugin                    Skills  Install Method"
    echo "  ────────────────────────  ──────  ─────────────────────────────────"
    echo "  eo-microsaas-os (v3.1.0)   13    Upload dist/eo-microsaas-os.plugin"
    echo "  smorch-gtm-engine (v2.0.0) 12    Upload dist/smorch-gtm-engine.plugin"
    echo "  eo-training-factory         1    Upload dist/eo-training-factory.plugin"
    echo "  eo-scoring-suite            5    Already installed (marketplace)"
    echo "  smorch-dev                 13    Already installed (marketplace)"
    echo "  mamoun-personal-branding    5    Already installed (marketplace)"
    echo "  smorch-context-brain        2    Already installed (marketplace)"
    echo "  smorch-design               5    Already installed (marketplace)"
    echo "  smorch-gtm-tools            5    Already installed (marketplace)"
    echo ""
    echo "  Anthropic built-in         16    Pre-installed with Cowork"
    echo ""
    echo "To upload a .plugin file: Cowork > Customize > Plugins > Upload"
    echo "Plugin files are at: smorch-brain/dist/"
}

MODE="${1:---all}"

case "$MODE" in
    --help|-h)
        show_help
        exit 0
        ;;
    --list-cowork)
        list_cowork
        exit 0
        ;;
    --lsp)
        echo -e "${GREEN}Installing LSP plugins (Claude Code only)...${NC}"
        for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp; do
            install_plugin "$p" "claude-plugins-official"
        done
        ;;
    --official)
        echo -e "${GREEN}Installing official Anthropic plugins (Claude Code only)...${NC}"
        for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp code-review frontend-design github; do
            install_plugin "$p" "claude-plugins-official"
        done
        ;;
    --gtm)
        echo -e "${GREEN}Installing GTM agents plugins (Claude Code only)...${NC}"
        for p in campaign-orchestration content-marketing customer-analytics email-marketing growth-experiments revenue-analytics sales-enablement sales-pipeline sales-prospecting; do
            install_plugin "$p" "gtm-agents"
        done
        ;;
    --typescript) install_plugin "typescript-lsp" "claude-plugins-official" ;;
    --python) install_plugin "pyright-lsp" "claude-plugins-official" ;;
    --rust) install_plugin "rust-analyzer-lsp" "claude-plugins-official" ;;
    --go) install_plugin "gopls-lsp" "claude-plugins-official" ;;
    --code-review) install_plugin "code-review" "claude-plugins-official" ;;
    --frontend) install_plugin "frontend-design" "claude-plugins-official" ;;
    --github) install_plugin "github" "claude-plugins-official" ;;
    --all)
        echo -e "${GREEN}Installing ALL Claude Code plugins...${NC}"
        echo ""
        echo -e "${CYAN}=== Official Anthropic (7 plugins) ===${NC}"
        for p in typescript-lsp pyright-lsp rust-analyzer-lsp gopls-lsp code-review frontend-design github; do
            install_plugin "$p" "claude-plugins-official"
        done
        echo ""
        echo -e "${CYAN}=== GTM Agents (9 plugins, 36 skills) ===${NC}"
        for p in campaign-orchestration content-marketing customer-analytics email-marketing growth-experiments revenue-analytics sales-enablement sales-pipeline sales-prospecting; do
            install_plugin "$p" "gtm-agents"
        done
        echo ""
        echo -e "${YELLOW}NOTE: Cowork-only plugins (9 total) must be installed via Desktop app.${NC}"
        echo -e "${YELLOW}Run: smorch-install-plugins --list-cowork${NC}"
        ;;
    *)
        echo "Unknown option: $MODE"
        show_help
        exit 1
        ;;
esac

echo ""
echo -e "${GREEN}Done!${NC} Restart Claude Code to activate new plugins."
