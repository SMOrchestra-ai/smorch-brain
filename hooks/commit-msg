#!/bin/bash
# commit-msg hook — validates conventional commit format
# Part of SMOrchestra-ai AI-Native GitHub Architecture

commit_msg_file="$1"
commit_msg=$(cat "$commit_msg_file")

# Skip merge commits
if echo "$commit_msg" | grep -qE "^Merge "; then
  exit 0
fi

# Skip revert commits
if echo "$commit_msg" | grep -qE "^Revert "; then
  exit 0
fi

# Validate conventional commit format
pattern="^(feat|fix|refactor|test|docs|chore|agent|hotfix)(\(.+\))?: .+"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Commit message does not follow conventional commit format."
  echo ""
  echo "Required format: type(scope): description"
  echo "  type: feat | fix | refactor | test | docs | chore | agent | hotfix"
  echo "  scope: optional, e.g. TASK-123"
  echo "  description: imperative mood, present tense"
  echo ""
  echo "Examples:"
  echo "  feat(TASK-184): add retry logic to queue consumer"
  echo "  fix(TASK-201): resolve null pointer on empty payload"
  echo "  agent(TASK-184): implement backoff — workers/queue.go"
  echo "  docs: update CHANGELOG for v3.0.0"
  echo ""
  echo "Your message: $commit_msg"
  echo ""
  exit 1
fi

exit 0
